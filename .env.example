# ══════════════════════════════════════════════════════════════════════════
# NexusOS 环境变量配置
# 复制此文件到 apps/api/.env 并填入实际值
# cp .env.example apps/api/.env
# ══════════════════════════════════════════════════════════════════════════

# ── 服务器 ─────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── 数据库 ─────────────────────────────────────────────────────────────────
DATABASE_URL=./data/nexusos.db
DATA_DIR=./data

# ── AI 模型 ────────────────────────────────────────────────────────────────
# OpenRouter API Key（支持 Claude/GPT/Gemini 等多模型）
# 获取：https://openrouter.ai/keys
ANTHROPIC_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Redis（任务队列） ──────────────────────────────────────────────────────
# 本地安装：brew install redis && brew services start redis
REDIS_URL=redis://localhost:6379

# ── 沙箱模式 ───────────────────────────────────────────────────────────────
# process = 本地进程执行（无需 Docker）
# docker  = Docker 容器隔离执行
SANDBOX_MODE=process
SANDBOX_IMAGE=nexusos-agent:latest
CLAUDE_BIN=claude
WORKSPACES_ROOT=./workspaces

# ── 远程 Docker 沙箱（可选） ───────────────────────────────────────────────
# 运行 scripts/setup-remote-docker.sh 配置云服务器后启用
# 然后将 SANDBOX_MODE 改为 docker
#
# DOCKER_HOST=tcp://YOUR_SERVER_IP:2376
# DOCKER_TLS_CA=../../docker-certs/ca.pem
# DOCKER_TLS_CERT=../../docker-certs/cert.pem
# DOCKER_TLS_KEY=../../docker-certs/key.pem
# REMOTE_WORKSPACES_ROOT=/opt/nexusos/workspaces

# ── 消息渠道（可选） ──────────────────────────────────────────────────────
# Telegram Bot — 从 @BotFather 获取
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 飞书 Bot — 从飞书开放平台获取
# FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 邮件（可选） ──────────────────────────────────────────────────────────
# 通过前端 MailApp 配置，无需在此设置

# ── 浏览器代理（可选） ────────────────────────────────────────────────────
# Chromium 路径（Docker 容器内默认 /usr/bin/chromium）
# CHROMIUM_PATH=/usr/bin/chromium
