# ─────────────────────────────────────────────────────────────────────────────
# NexusOS Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── Database ────────────────────────────────────────────────────────────────
# Path to the SQLite database file
DATABASE_URL=./data/nexusos.db
DATA_DIR=./data

# ── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ── Sandbox ─────────────────────────────────────────────────────────────────
# process = run commands in isolated directories (default, no Docker needed)
# docker  = run commands inside Docker containers (requires Docker)
SANDBOX_MODE=process
SANDBOX_IMAGE=nexusos-agent:latest
CLAUDE_BIN=claude

# ── Redis (required for task queue) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Workspace ───────────────────────────────────────────────────────────────
# Where agent workspaces are stored on disk
WORKSPACES_ROOT=./workspaces
